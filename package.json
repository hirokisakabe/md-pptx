{
  "name": "md-pptx",
  "displayName": "md-pptx",
  "version": "0.0.0",
  "description": "Markdown とテンプレート PPTX から編集可能な PowerPoint ファイルを生成するツール",
  "publisher": "hirokisakabe",
  "type": "module",
  "main": "./dist/extension.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "md-pptx": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "contributes": {
    "commands": [
      {
        "command": "md-pptx.build",
        "title": "md-pptx: Build PPTX"
      },
      {
        "command": "md-pptx.preview",
        "title": "md-pptx: Preview"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "md-pptx.build",
          "when": "editorLangId == markdown"
        },
        {
          "command": "md-pptx.preview",
          "when": "editorLangId == markdown"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build && npm run build:extension",
    "build": "tsup",
    "build:extension": "node esbuild.mjs",
    "dev": "tsup --watch",
    "watch:extension": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:e2e": "bash e2e/scripts/download-recipes.sh && vitest run --config vitest.config.e2e.ts",
    "test:e2e:setup": "bash e2e/scripts/download-recipes.sh",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package": "vsce package"
  },
  "keywords": [],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "jszip": "^3.10.1",
    "markdown-it": "^14.1.1",
    "pyodide": "^0.28.3",
    "python-pptx-wasm": "^0.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
