{
  "name": "md-pptx",
  "displayName": "md-pptx",
  "version": "0.5.1",
  "description": "Markdown から編集可能な PowerPoint ファイルを生成するツール",
  "publisher": "hirokisakabe",
  "repository": {
    "type": "git",
    "url": "https://github.com/hirokisakabe/md-pptx.git"
  },
  "type": "module",
  "main": "./dist/extension.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "md-pptx": "./dist/cli.js"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "icon": "images/icon.png",
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "contributes": {
    "commands": [
      {
        "command": "md-pptx.build",
        "title": "md-pptx: Build PPTX"
      },
      {
        "command": "md-pptx.preview",
        "title": "md-pptx: Preview",
        "icon": {
          "light": "images/icon.png",
          "dark": "images/icon.png"
        }
      }
    ],
    "configuration": {
      "title": "md-pptx",
      "properties": {
        "md-pptx.defaultOutputDirectory": {
          "type": "string",
          "default": "",
          "description": "PPTX ファイルのデフォルト出力先ディレクトリ。空の場合は Markdown ファイルと同じディレクトリが使用されます。"
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "md-pptx.build",
          "when": "editorLangId == markdown"
        },
        {
          "command": "md-pptx.preview",
          "when": "editorLangId == markdown"
        }
      ],
      "editor/title": [
        {
          "command": "md-pptx.preview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build && npm run build:extension",
    "build": "tsup",
    "build:extension": "node esbuild.mjs",
    "dev": "tsup --watch",
    "watch:extension": "node esbuild.mjs --watch",
    "test": "vitest run",
    "test:e2e": "bash e2e/scripts/download-recipes.sh && vitest run --config vitest.config.e2e.ts",
    "test:e2e:setup": "bash e2e/scripts/download-recipes.sh",
    "vrt:generate-fixtures": "npx tsx vrt/libreoffice/generate_fixtures.ts",
    "vrt:libreoffice": "vitest run --config vitest.config.vrt.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package": "vsce package",
    "version": "changeset version && npm install --package-lock-only"
  },
  "keywords": [],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "jszip": "^3.10.1",
    "markdown-it": "^14.1.1",
    "pptx-glimpse": "^0.6.1",
    "pyodide": "^0.28.3",
    "python-pptx-wasm": "^0.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
