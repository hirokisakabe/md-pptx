{
  "name": "md-pptx-vscode",
  "displayName": "md-pptx",
  "description": "Marp風Markdown → テンプレートPPTX出力ツール",
  "version": "0.0.0",
  "publisher": "hirokisakabe",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md-pptx.build",
        "title": "md-pptx: Build PPTX"
      },
      {
        "command": "md-pptx.preview",
        "title": "md-pptx: Preview"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "md-pptx.build",
          "when": "editorLangId == markdown"
        },
        {
          "command": "md-pptx.preview",
          "when": "editorLangId == markdown"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "package": "vsce package"
  },
  "dependencies": {
    "md-pptx": "file:.."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
